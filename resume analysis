<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SmartHire – Admin Dashboard</title>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            /* Color Palette - Matching Scoring Definition */
            --primary: #3B5BDB;
            --primary-indigo: #364FC7;
            --sidebar-gradient-top: #2F3E9E;
            --sidebar-gradient-bottom: #1E2A78;

            --bg-main: #EEF1FF;
            --bg-card: #FFFFFF;

            --status-success: #2F9E44;
            --status-bg-success: #EBFBEE;
            --status-warning: #F08C00;
            --status-bg-warning: #FFF4E6;
            --status-error: #E03131;
            --status-bg-error: #FFF5F5;
            --status-info: #0CA678;
            --status-bg-info: #E6FCF5;

            --text-primary: #1C1F2A;
            --text-secondary: #5C6270;
            --text-muted: #8B90A0;

            --border-light: #E5E7EB;
            --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
            --shadow-premium: 0 20px 25px -5px rgba(0, 0, 0, 0.08);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }

        body {
            display: flex;
            height: 100vh;
            background: var(--bg-main);
            color: var(--text-primary);
        }

        .sidebar {
            width: 260px;
            background: linear-gradient(180deg, var(--sidebar-gradient-top) 0%, var(--sidebar-gradient-bottom) 100%);
            color: white;
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 100;
        }

        .logo-area {
            padding: 24px;
            font-size: 22px;
            font-weight: 700;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-menu {
            flex: 1;
            padding: 20px 0;
            overflow-y: auto;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 12px 24px;
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            transition: 0.2s;
            font-size: 14px;
            font-weight: 500;
        }

        .nav-item:hover {
            color: white;
            background: rgba(255, 255, 255, 0.1);
        }

        .nav-item.active {
            color: white;
            background: rgba(255, 255, 255, 0.15);
            border-left: 4px solid var(--status-info);
        }

        .nav-item i {
            width: 24px;
            margin-right: 10px;
        }

        .main {
            flex: 1;
            margin-left: 260px;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .header {
            height: 70px;
            background: var(--bg-card);
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            flex-shrink: 0;
        }

        .header-title h2 {
            font-size: 18px;
            font-weight: 600;
        }

        .header-title span {
            font-size: 13px;
            color: var(--text-secondary);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

        .avatar {
            width: 36px;
            height: 36px;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            font-size: 14px;
        }

        .dashboard {
            flex: 1;
            overflow-y: auto;
            padding: 30px;
        }

        .kpi-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
            align-items: start;
        }

        .main-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            align-items: stretch;
        }

        .card {
            background: var(--bg-card);
            padding: 24px;
            border-radius: 16px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            margin-bottom: 0;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

        .card-title {
            font-weight: 600;
            margin-bottom: 18px;
            font-size: 14px;
        }

        /* --- Enhanced KPI Cards --- */
        .kpi-card {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px;
        }

        .kpi-info h3 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 2px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .trend-badge {
            font-size: 11px;
            padding: 2px 6px;
            border-radius: 4px;
            font-weight: 600;
        }

        .trend-up {
            background: #EBFBEE;
            color: #2F9E44;
        }

        .trend-neutral {
            background: #F8F9FA;
            color: #868E96;
        }

        .kpi-info p {
            font-size: 12px;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .icon-container {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            flex-shrink: 0;
        }

        /* --- Operational KPI Sub-metrics --- */
        .kpi-details {
            margin-top: 12px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px 16px;
            border-top: 1px solid var(--border-light);
            padding: 12px 16px;
            background: linear-gradient(to bottom, rgba(248, 249, 250, 0.4), rgba(248, 249, 250, 0.8));
            margin: 12px -16px 0 -16px;
        }

        .kpi-details.three-cols {
            grid-template-columns: repeat(3, 1fr);
        }

        .detail-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 11px;
        }

        .detail-item.stacked {
            flex-direction: column;
            align-items: flex-start;
            gap: 4px;
        }

        .detail-label {
            color: var(--text-secondary);
            font-weight: 500;
            white-space: nowrap;
        }

        .detail-value {
            font-weight: 700;
            color: var(--text-primary);
        }

        .kpi-comparison {
            padding: 4px 16px 12px;
            font-size: 10px;
            color: var(--text-muted);
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 4px;
            background: rgba(248, 249, 250, 0.6);
            border-radius: 0 0 16px 16px;
            margin: 0 -16px -16px -16px;
        }

        .comparison-up {
            color: var(--status-success);
        }

        .comparison-neutral {
            color: var(--text-muted);
        }

        .status-pill {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .status-pill.healthy {
            background: #E6FCF5;
            color: #0CA678;
            border: 1px solid #12B886;
        }

        .status-pill.degraded {
            background: #FFF9DB;
            color: #F08C00;
            border: 1px solid #FAB005;
        }

        .status-pill.critical {
            background: #FFF5F5;
            color: #E03131;
            border: 1px solid #FA5252;
        }

        .icon-blue {
            background: #E7F5FF;
            color: #1971C2;
        }

        .icon-teal {
            background: #E6FCF5;
            color: #0CA678;
        }

        .icon-green {
            background: #EBFBEE;
            color: #2F9E44;
        }

        .icon-indigo {
            background: #EDF2FF;
            color: #364FC7;
        }

        .icon-amber {
            background: #FFF9DB;
            color: #E67700;
        }

        .metric-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            font-size: 13px;
        }

        .metric-label {
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--text-secondary);
        }

        .metric-value {
            font-weight: 600;
        }

        .metric-time {
            font-size: 11px;
            font-weight: 500;
        }

        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            display: inline-block;
        }

        .progress {
            height: 6px;
            background: #f1f3f5;
            border-radius: 3px;
            margin: 6px 0 12px 0;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            border-radius: 3px;
            transition: width 0.5s ease;
        }

        .list-item {
            display: flex;
            justify-content: space-between;
            padding: 12px 0;
        }

        /* --- Monitoring Tables Styling --- */
        .dashboard-table-container {
            width: 100%;
            overflow-x: auto;
        }

        .dashboard-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12px;
            margin-top: 8px;
        }

        .dashboard-table th {
            text-align: left;
            padding: 8px 10px;
            background: #F8F9FA;
            color: var(--text-secondary);
            font-weight: 600;
            border-bottom: 1px solid var(--border-light);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-size: 10px;
        }

        .dashboard-table td {
            padding: 8px 10px;
            border-bottom: 1px solid var(--border-light);
            color: var(--text-primary);
            vertical-align: middle;
        }

        .dashboard-table tr:hover {
            background-color: #fcfcfd;
        }

        .badge {
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: 600;
            display: inline-block;
        }

        .badge-active {
            background: #EBFBEE;
            color: #2F9E44;
        }

        .badge-inactive {
            background: #F8F9FA;
            color: #868E96;
        }

        .badge-locked {
            background: #FFF5F5;
            color: #E03131;
        }

        .badge-success {
            background: #E6FCF5;
            color: #0CA678;
        }

        .badge-failed {
            background: #FFF5F5;
            color: #E03131;
        }

        .view-all-link {
            display: inline-block;
            margin-top: 18px;
            font-size: 13px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            transition: 0.2s;
        }

        .view-all-link:hover {
            color: var(--primary-indigo);
            text-decoration: underline;
        }


        .btn-apply {
            background: var(--primary);
            color: white;
            border: none;
            padding: 7px 20px;
            border-radius: 6px;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            gap: 8px;
            box-shadow: 0 4px 6px -1px rgba(59, 91, 219, 0.2);
        }

        .btn-apply:hover {
            background: var(--primary-indigo);
            transform: translateY(-1px);
            box-shadow: 0 6px 12px -2px rgba(59, 91, 219, 0.3);
        }

        .btn-apply:active {
            transform: translateY(0);
        }

        .btn-apply i {
            font-size: 11px;
        }

        /* --- AI Monitoring Alerts & Badges --- */
        .alert-warning {
            border: 2px solid var(--status-warning) !important;
        }

        .alert-critical {
            border: 2px solid var(--status-error) !important;
        }

        .health-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .health-green {
            background: var(--status-bg-success);
            color: var(--status-success);
        }

        .health-yellow {
            background: var(--status-bg-warning);
            color: var(--status-warning);
        }

        .health-red {
            background: var(--status-bg-error);
            color: var(--status-error);
        }

        .metric-subtext {
            font-size: 11px;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .warning-text {
            color: var(--status-error);
            font-weight: 600;
            font-size: 11px;
            margin-top: 4px;
            display: block;
        }

        .chart-legend-custom {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 10px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 10px;
            color: var(--text-secondary);
        }

        .legend-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }


        /* --- Visualization Layouts --- */

        /* --- Visualization Layouts --- */
        .viz-container {
            display: flex;
            align-items: center;
            gap: 20px;
        }

        .chart-box-small {
            width: 120px;
            height: 120px;
            flex-shrink: 0;
        }

        .radar-box {
            margin-top: 10px;
        }

        .scoring-metric {
            margin-bottom: 12px;
        }

        .scoring-metric-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 4px;
        }

        .scoring-metric-label {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .scoring-metric-value {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .scoring-progress {
            height: 6px;
            background: #f1f3f5;
            border-radius: 3px;
            overflow: hidden;
        }

        .scoring-progress-fill {
            height: 100%;
            border-radius: 3px;
        }

        .chart-box-audit {
            height: 180px;
            margin-top: 10px;
        }

        /* Modal Styles */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.5);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(2px);
        }

        .modal-overlay.show {
            display: flex;
        }

        .modal-content {
            background: white;
            width: 80%;
            max-width: 900px;
            height: 85vh;
            border-radius: 12px;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: slideUp 0.3s ease-out;
        }

        @keyframes slideUp {
            from {
                transform: translateY(20px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .modal-header {
            background-color: var(--primary);
            padding: 12px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            flex-shrink: 0;
        }

        .modal-title {
            font-size: 16px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .modal-subtitle {
            font-size: 12px;
            color: rgba(255, 255, 255, 0.8);
            font-weight: 400;
            margin-left: 8px;
        }

        .close-btn {
            background: transparent;
            border: none;
            color: white;
            font-size: 20px;
            cursor: pointer;
            width: 30px;
            height: 30px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
            transition: background 0.2s;
        }

        .close-btn:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .modal-body {
            flex: 1;
            padding: 0;
            /* Remove padding for iframe */
            background: #f8f9fa;
            position: relative;
        }

        .resume-preview-frame {
            width: 100%;
            height: 100%;
            border: none;
        }

        /* Placeholder for demo purposes */
        .pdf-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            background-color: #525659;
            color: white;
            position: relative;
        }

        .pdf-viewer-content {
            display: flex;
            flex: 1;
            overflow: hidden;
            width: 100%;
        }

        .pdf-sidebar {
            width: 200px;
            background-color: #3e4143;
            border-right: 1px solid rgba(255, 255, 255, 0.1);
            transition: transform 0.3s ease, width 0.3s ease, margin-left 0.3s ease;
            overflow-y: auto;
            flex-shrink: 0;
            padding: 20px;
        }

        .pdf-sidebar.collapsed {
            width: 0;
            padding: 0;
            margin-left: -200px;
            transform: translateX(-100%);
        }

        .pdf-sidebar-title {
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: rgba(255, 255, 255, 0.5);
            margin-bottom: 16px;
            letter-spacing: 0.5px;
        }

        .pdf-thumbnail {
            width: 100%;
            aspect-ratio: 1 / 1.4;
            background: white;
            margin-bottom: 20px;
            border: 2px solid transparent;
            cursor: pointer;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #ccc;
            font-size: 12px;
        }

        .pdf-thumbnail.active {
            border-color: #3b5bdb;
        }

        .pdf-thumbnail:hover {
            border-color: rgba(255, 255, 255, 0.3);
        }

        .pdf-main-view {
            flex: 1;
            display: flex;
            justify-content: center;
            padding: 24px;
            overflow-y: auto;
            background-color: #525659;
        }

        .pdf-page-mockup {
            width: 100%;
            max-width: 600px;
            background: white;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
            padding: 40px;
            height: fit-content;
            min-height: 800px;
            color: #333;
        }

        .pdf-toolbar {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 40px;
            background: #323639;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 16px;
            color: white;
            font-size: 13px;
        }

        .pdf-controls {
            display: flex;
            gap: 16px;
        }

        .pdf-control-icon {
            cursor: pointer;
            opacity: 0.8;
            transition: opacity 0.2s;
        }

        .pdf-control-icon:hover {
            opacity: 1;
        }

        .scoring-metric-label {
            font-size: 11px;
            font-weight: 600;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .scoring-metric-value {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-primary);
        }

        .scoring-progress {
            height: 6px;
            background: #f1f3f5;
            border-radius: 3px;
            overflow: hidden;
        }

        .scoring-progress-fill {
            height: 100%;
            border-radius: 3px;
        }

        .chart-box-audit {
            height: 180px;
            margin-top: 10px;
        }

        @media(max-width:1100px) {
            .main-grid {
                grid-template-columns: 1fr;
            }

            .sidebar {
                display: none;
            }
        }
    </style>
</head>

<body>

    <aside class="sidebar">
        <div class="logo-area"><i class="fa-solid fa-briefcase"></i> SmartHire</div>
        <nav class="nav-menu">
            <a href="#" class="nav-item"><i class="fa-solid fa-gauge-high"></i> Dashboard</a>
            <a href="#" class="nav-item active"><i class="fa-solid fa-file-invoice"></i> Resume Analysis</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-user-shield"></i> User Management</a>
            <a href="#" class="nav-item "><i class="fa-solid fa-hammer"></i> Scoring Config</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-database"></i> Backup Configuration</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-history"></i> Audit Logs</a>
        </nav>
    </aside>

    <div class="main">

        <div class="header">
            <div class="header-title">
                <h2>Resume Analyzed Details</h2>
                <span>AI Processing & Queue Management</span>
            </div>
            <div class="user-profile">
                <div class="avatar">AD</div>
                <span style="font-size: 14px; font-weight: 500;">Admin User</span>
            </div>
        </div>

        <div class="dashboard">
            <div style="display: flex; justify-content: flex-end; align-items: center; gap: 12px; margin-bottom: 20px;">
                <span style="font-size: 13px; font-weight: 500; color: var(--text-secondary);">Date Range:</span>
                <input type="date" value="2026-02-21" id="fromDate"
                    style="padding: 6px 10px; border: 1px solid var(--border-light); border-radius: 4px; font-size: 13px; color: var(--text-primary); outline: none;">
                <span style="color: var(--text-muted); font-size: 13px;">to</span>
                <input type="date" value="2026-02-27" id="toDate"
                    style="padding: 6px 10px; border: 1px solid var(--border-light); border-radius: 4px; font-size: 13px; color: var(--text-primary); outline: none;">
                <button class="btn-apply" onclick="applyDateFilters()">
                    <i class="fa-solid fa-filter"></i> Apply
                </button>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px;">
                <!-- KPI 1: Successful -->
                <div class="card" style="margin-bottom: 0;">
                    <div style="display: flex; justify-content: space-between; align-items: center;">
                        <span style="font-size: 14px; font-weight: 600; color: var(--text-secondary);">Total
                            Successfully Analyzed Resumes</span>
                        <div class="icon-container icon-green">
                            <i class="fa-solid fa-check-double"></i>
